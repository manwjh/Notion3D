# Notion3D 共享配置 — 复制为 .env

# Web 对话 Agent 由 make dev AGENT=... 注入（cursor_sdk | hermes | engine）

# --- cursor_sdk ---
# CURSOR_API_KEY=

# --- hermes（与 ~/.hermes/.env 中 API_SERVER_KEY 一致）---
# HERMES_API_SERVER_KEY=change-me-local-dev
# NOTION3D_HERMES_API_BASE=http://127.0.0.1:8642

NOTION3D_WEB_BASE=http://localhost:5173
# 局域网分享链接：NOTION3D_WEB_BASE=http://<本机 IP>:5173
