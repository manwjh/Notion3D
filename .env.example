# Notion3D 共享配置 — 复制为 .env
# 依赖：docs/dependencies.md · 本机/内网：docs/usage-network.md

# ── 系统要求 ──
# Python 3.11+ · Node.js 20+ · git
# make install  →  api + mcp-server + forge-runner + web + agent-bridge

# ── 工作台 URL（决定分享链接与 MCP 预览链接）──
#
# 【本机 Local】浏览器与 make dev 同一台电脑 — 用默认即可：
NOTION3D_WEB_BASE=http://localhost:5173
NOTION3D_API_BASE=http://127.0.0.1:8000
#
# 【局域网 LAN】同事/手机同 Wi‑Fi 访问 — 改为主机 IP 并重启 make dev：
# NOTION3D_WEB_BASE=http://192.168.1.42:5173
# NOTION3D_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.42:5173
# Agent 在另一台内网 PC 时，MCP env 也用上述 IP（见 usage-network.md）

# ── Web Turn 侧car（可选，浏览器内 POST /turn）──
# make dev 默认 off；或 make dev WEB_TURN=bridge|gateway
# NOTION3D_WEB_TURN=off

# bridge — LLM 经 Cursor 云端；sidecar 内还需 notion3d-mcp（make install）
# CURSOR_API_KEY=
# NOTION3D_WEB_TURN_BRIDGE_BASE=http://127.0.0.1:8787

# gateway — 当前实现 Hermes；LLM 在 gateway 宿主，不在 Notion3D
# NOTION3D_WEB_TURN_GATEWAY_BIN=hermes
# NOTION3D_WEB_TURN_GATEWAY_BASE=http://127.0.0.1:8642
# HERMES_API_SERVER_KEY=

# ── MCP（标准 Agent 接入，接口 1）──
# Agent 宿主配置 notion3d-mcp；LLM 在宿主侧
#   NOTION3D_API_BASE=http://127.0.0.1:8000
#   NOTION3D_WEB_BASE=http://localhost:5173
# 见 docs/agents/README.md · docs/dependencies.md
