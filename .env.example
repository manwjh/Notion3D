# Notion3D 共享配置 — 复制为 .env

# auto | cursor_sdk | openclaw | cursor_cloud
NOTION3D_AGENT_PROVIDER=auto

# --- Cursor SDK local（推荐：只需 CURSOR_API_KEY，无需 tunnel）---
# Dashboard → Integrations
# CURSOR_API_KEY=
# make bridge  或  make dev（自动启动 bridge :8787）

# --- OpenClaw（本地）---

# --- Cursor Cloud Agents API（需 NOTION3D_PUBLIC_API_BASE 公网 tunnel）---
# CURSOR_API_KEY=
# NOTION3D_PUBLIC_API_BASE=https://...

NOTION3D_WEB_BASE=http://localhost:5173
