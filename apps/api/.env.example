# API 进程环境 — 复制为 apps/api/.env 或由根目录 .env 经 scripts/with-env.sh 注入
# 完整说明：docs/dependencies.md · 根目录 .env.example

NOTION3D_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 工作台链接（API / MCP / bridge 共用）
NOTION3D_WEB_BASE=http://localhost:5173
# 局域网：NOTION3D_WEB_BASE=http://<本机 IP>:5173

# Web Turn 侧car（可选）— 见 docs/dependencies.md
# NOTION3D_WEB_TURN=off
# NOTION3D_WEB_TURN_BRIDGE_BASE=http://127.0.0.1:8787
# NOTION3D_WEB_TURN_GATEWAY_BASE=http://127.0.0.1:8642
